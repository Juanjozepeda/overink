{
  "name": "overink",
  "version": "0.1.3",
  "description": "Pressure-sensitive vector ink layer you can mount on top of any editor. Palm rejection, low latency, strokes as portable JSON.",
  "license": "MIT",
  "author": "Juan José Zepeda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juanjozepeda/overink.git",
    "directory": "packages/overink"
  },
  "homepage": "https://github.com/Juanjozepeda/overink#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ink",
    "canvas",
    "stylus",
    "apple-pencil",
    "handwriting",
    "drawing",
    "annotation",
    "freehand",
    "perfect-freehand",
    "palm-rejection",
    "tiptap"
  ],
  "dependencies": {
    "perfect-freehand": "^1.2.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
